  <!--
    Import Map — tells the browser WHERE to load each micro-app bundle from.

    In local dev:  each micro-app runs its own Vite dev server on a different port.
    In production: each URL points to the S3/CloudFront hosted bundle.

    This is the KEY config that wires the shell to each micro-app.
    You change URLs here when you deploy — the shell code itself never changes.
  -->
  <script type="importmap">
    {
      "imports": {
        "single-spa":       "https://cdn.jsdelivr.net/npm/single-spa@6.0.3/lib/es2015/esm/single-spa.min.js",
        "react":            "https://esm.sh/react@18.3.1",
        "react-dom":        "https://esm.sh/react-dom@18.3.1",
        "react-dom/client": "https://esm.sh/react-dom@18.3.1/client",
        "single-spa-react": "https://esm.sh/single-spa-react@6.0.0",

        "@rootcause/home":      "//localhost:3001/mfe-home.js",
        "@rootcause/interview": "//localhost:3002/mfe-interview.js",
        "@rootcause/articles":  "//localhost:3003/mfe-articles.js",
        "@rootcause/fixes":     "//localhost:3004/mfe-fixes.js",
        "@rootcause/payment":   "//localhost:3005/mfe-payment.js"
      }
    }
  </script>

